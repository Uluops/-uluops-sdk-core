{
  "name": "@uluops/sdk-core",
  "version": "0.1.2",
  "description": "Shared infrastructure for UluOps SDKs",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./http": {
      "import": "./dist/http/index.js",
      "types": "./dist/http/index.d.ts"
    },
    "./errors": {
      "import": "./dist/errors/index.js",
      "types": "./dist/errors/index.d.ts"
    },
    "./config": {
      "import": "./dist/config/index.js",
      "types": "./dist/config/index.d.ts"
    },
    "./config/constants": {
      "import": "./dist/config/constants.js",
      "types": "./dist/config/constants.d.ts"
    },
    "./utils": {
      "import": "./dist/utils/index.js",
      "types": "./dist/utils/index.d.ts"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "uluops",
    "sdk",
    "core",
    "infrastructure"
  ],
  "author": "UluOps <hello@uluops.ai>",
  "publishConfig": {
    "access": "restricted"
  },
  "bugs": {
    "url": "https://github.com/uluops/uluops/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/uluops/uluops.git",
    "directory": "packages/sdk-core"
  },
  "homepage": "https://github.com/uluops/uluops/tree/main/packages/sdk-core#readme",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.2.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^22.12.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.2",
    "nock": "^14.0.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^3.0.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
